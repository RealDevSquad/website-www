<div class="step-container">
  <div class="form-header__text">
    <h1 class="section-heading">{{@heading}}</h1>
    <p class="section-instruction">{{@subHeading}}</p>
  </div>

  <Reusables::InputBox
    @field="Phone Number"
    @name="phoneNumber"
    @placeHolder="+91 80000 00000"
    @type="tel"
    @required={{true}}
    @value={{this.data.phoneNumber}}
    @onInput={{this.inputHandler}}
    @variant="input--full-width"
  />
  {{#if this.errorMessage.phoneNumber}}
    <div
      class="error__message"
      data-test-error="phoneNumber"
    >{{this.errorMessage.phoneNumber}}</div>
  {{/if}}

  <div class="input-box input--full-width">
    <label class="label" for="twitter">Twitter
      <span class="required">*</span></label>
    <div class="social-input-wrapper">
      <span class="social-input-prefix">{{this.getSocialPrefix
          "twitter"
        }}/</span>
      <input
        name="twitter"
        class="social-input-field"
        type="text"
        id="twitter"
        placeholder="username"
        required="required"
        value={{this.data.twitter}}
        {{on "input" this.inputHandler}}
      />
    </div>
  </div>
  {{#if this.errorMessage.twitter}}
    <div class="error__message">{{this.errorMessage.twitter}}</div>
  {{/if}}

  {{#if this.showGitHub}}
    <div class="input-box input--full-width">
      <label class="label" for="github">GitHub
        <span class="required">*</span></label>
      <div class="social-input-wrapper">
        <span class="social-input-prefix">{{this.getSocialPrefix
            "github"
          }}/</span>
        <input
          name="github"
          class="social-input-field"
          type="text"
          id="github"
          placeholder="username"
          required="required"
          value={{this.data.github}}
          {{on "input" this.inputHandler}}
        />
      </div>
    </div>
    {{#if this.errorMessage.github}}
      <div class="error__message">{{this.errorMessage.github}}</div>
    {{/if}}
  {{/if}}

  <div class="input-box input--full-width">
    <label class="label" for="linkedin">LinkedIn
      <span class="required">*</span></label>
