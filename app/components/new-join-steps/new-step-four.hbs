      <span class="social-input-prefix">{{this.getSocialPrefix
          "linkedin"
        }}/</span>
      <input
        name="linkedin"
        class="social-input-field"
        type="text"
        id="linkedin"
        placeholder="username"
        required="required"
        value={{this.data.linkedin}}
        {{on "input" this.inputHandler}}
      />
    </div>
  </div>
  {{#if this.errorMessage.linkedin}}
    <div class="error__message">{{this.errorMessage.linkedin}}</div>
  {{/if}}

  <div class="input-box input--full-width">
    <label class="label" for="instagram">Instagram</label>
    <div class="social-input-wrapper">
      <span class="social-input-prefix">{{this.getSocialPrefix
          "instagram"
        }}/</span>
      <input
        name="instagram"
        class="social-input-field"
        type="text"
        id="instagram"
        placeholder="username"
        value={{this.data.instagram}}
        {{on "input" this.inputHandler}}
      />
    </div>
  </div>
  {{#if this.errorMessage.instagram}}
    <div class="error__message">{{this.errorMessage.instagram}}</div>
  {{/if}}

  <div class="input-box input--full-width">
    <label class="label" for="peerlist">Peerlist
      <span class="required">*</span></label>
    <div class="social-input-wrapper">
      <span class="social-input-prefix">{{this.getSocialPrefix
